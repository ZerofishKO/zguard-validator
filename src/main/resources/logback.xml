<configuration>
    <!-- 控制台输出 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- 自定义日志格式：时间 [线程] 级别 日志器名 - 消息%n -->
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 设置根日志级别为 INFO -->
    <root level="error">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- 如果需要，可以单独为某个包设置更详细的级别，例如：
    <logger name="org.example.core" level="DEBUG" />
    -->
</configuration>